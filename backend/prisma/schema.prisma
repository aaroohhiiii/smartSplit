
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
    
}


model Group{

  id String @id @default(uuid()) 
  name String 
  description String?
  createdAt DateTime  @default(now())
  createdBy String 
  currency String 
  members  GroupMember[]
  expenses Expense[]
  settlements Settlement[]
  billUploads BillUpload[] 
}


model GroupMember{
  id String @id @default(uuid())
  group  Group  @relation(fields :[groupId],references:[id])
  groupId  String 
  userId String 
  isVegetarian Boolean
  drinksAlcohol  Boolean 
  role  GroupRole
  joinedAt  DateTime @default(now())
}


enum GroupRole{
  OWNER 
  MEMBER
}

model Expense {
 id   String     @id  @default(uuid())
 groupId String 
 group Group @relation(fields:[groupId] , references:[id])
 title String
 description String?
 createdAt DateTime @default(now())
 createdBy String 
 paidBy String 
 currency String
 taxAmount Decimal @default(0)
 items ExpenseItem[]
 splitAllocations SplitAllocation[]


}

model ExpenseItem{
  id String @id @default(uuid())
  expense Expense @relation(fields:[expenseId],references:[id])
  expenseId String 
  name String
  amount Decimal
  category ExpenseCategory 
  participants ItemParticipant[]
}

enum ExpenseCategory{
VEG 
NON_VEG
ALCOHOL 
SHARED
}


model ItemParticipant{
id String @id @default(uuid())
expenseItem ExpenseItem @relation(fields:[expenseItemId],references:[id])
expenseItemId String 
userId String 
}

model SplitAllocation{
id String  @id @default(uuid())
expense Expense @relation(fields:[expenseId],references:[id])
expenseId String
userId String
amount Decimal
paid Decimal @default(0)



}

model Settlement{
id String @id @default(uuid())
groupId String 
group Group @relation(fields:[groupId],references:[id])
fromUserId String
toUserId String
amount Decimal
createdAt DateTime @default(now())

}


model BillUpload{
id String @id @default(uuid())
groupId String
group Group @relation(fields:[groupId],references:[id])
uploadedBy String
fileUrl String
status BillStatus
uploadedAt DateTime @default(now())
parsedBill ParsedBill?
aiJob AIProcessingJob?
}
enum BillStatus{
  UPLOADED
  PROCESSING
  COMPLETED
  FAILED
}
model ParsedBill{
 id           String      @id @default(uuid())
 billUpload BillUpload @relation(fields:[billUploadId],references:[id])
 billUploadId String  @unique
 items Json
 totalAmount Decimal
 completedAt DateTime?
}

model AIProcessingJob {
  id           String      @id @default(uuid())
  billUpload   BillUpload  @relation(fields: [billUploadId], references: [id])
  billUploadId String  @unique
  status       JobStatus
  startedAt    DateTime    @default(now())
  finishedAt   DateTime?
  error        String?
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}